#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    show_song_table_header: true,
    format_tag_separator: " • ",
    browser_column_widths: [20, 38, 42],
    background_color: "#292522",
    modal_backdrop: true,
    text_color: "#ECE1D7",
    header_background_color: "#292522",
    modal_background_color: "#292522",
    preview_label_style: (fg: "#C1A78E"),
    preview_metadata_group_style: (fg: "#E08A3C", modifiers: "Bold"),
    song_table_album_separator: None,
    tab_bar: (
        active_style: (fg: "#292522", bg: "#E08A3C", modifiers: "Bold"),
        inactive_style: (fg: "#867462"),
    ),
    highlighted_item_style: (fg: "#E49B5D", modifiers: "Bold"),
    current_item_style: (fg: "#292522", bg: "#E08A3C", modifiers: "Bold"),
    borders_style: (fg: "#E08A3C"),
    highlight_border_style: (fg: "#E08A3C"),
    symbols: (
        song: "󰝚 ", dir: "󰉋 ", playlist: "󰲸 ", marker: "● ", ellipsis: "…",
        song_style: (fg: "#C1A78E"), dir_style: (fg: "#E08A3C"), playlist_style: (fg: "#E49B5D"),
        marker_style: (fg: "#D47766"),
    ),
    progress_bar: (
        symbols: ["", "━", "󰝥", "┄", ""],
        track_style: (fg: "#403A36"),
        elapsed_style: (fg: "#E08A3C"),
        thumb_style: (fg: "#E49B5D", modifiers: "Bold"),
        use_track_when_empty: true,
    ),
    scrollbar: (
        symbols: ["│", "█", "", ""],
        track_style: (fg: "#403A36"),
        ends_style: (fg: "#403A36"),
        thumb_style: (fg: "#E08A3C"),
    ),
    song_table_format: [
        (prop: (kind: Property(Artist), style: (fg: "#E08A3C"),
            default: (kind: Text("Unknown Artist"), style: (fg: "#867462"))),
            width: "25%",
            label_prop: (kind: Group([
                (kind: Text("Artista "), style: (fg: "#ECE1D7")),
                (kind: Text(""), style: (fg: "#E08A3C")),
            ])),
        ),
        (prop: (kind: Property(Title), style: (fg: "#ECE1D7"),
            default: (kind: Property(Filename), style: (fg: "#ECE1D7"))),
            width: "45%",
            label_prop: (kind: Group([
                (kind: Text("Título "), style: (fg: "#ECE1D7")),
                (kind: Text("󰝚"), style: (fg: "#E08A3C")),
            ])),
        ),
        (prop: (kind: Property(Album), style: (fg: "#867462"),
            default: (kind: Text("Unknown Album"), style: (fg: "#867462"))),
            width: "22%",
            label_prop: (kind: Group([
                (kind: Text("Álbum "), style: (fg: "#ECE1D7")),
                (kind: Text("󰀥"), style: (fg: "#E08A3C")),
            ])),
        ),
        (prop: (kind: Property(Duration), style: (fg: "#C1A78E"),
            default: (kind: Text("-"))),
            width: "8%",
            alignment: Right,
            label_prop: (kind: Group([
                (kind: Text(" "), style: (fg: "#E08A3C")),
            ])),
        ),
    ],
    layout: Split(direction: Vertical, panes: [
        (size: "6", borders: "NONE", pane: Component("header")),
        (size: "100%", borders: "NONE", pane: Pane(TabContent)),
        (size: "3", borders: "ALL", border_symbols: Rounded,
            border_title: [
                (kind: Text("╴"), style: (fg: "#E08A3C")),
                (kind: Property(Status(Elapsed)), style: (fg: "#ECE1D7")),
                (kind: Property(Status(StateV2(playing_label: " 󰐊 ", paused_label: " 󰏤 ", stopped_label: " 󰓛 "))),
                    style: (fg: "#E08A3C", modifiers: "Bold")),
                (kind: Property(Status(Duration)), style: (fg: "#ECE1D7")),
                (kind: Text("╶"), style: (fg: "#E08A3C")),
            ],
            border_title_position: Top,
            border_title_alignment: Center,
            pane: Pane(ProgressBar),
        ),
    ]),
    browser_song_format: [
        (kind: Group([
            (kind: Property(Track)),
            (kind: Text(" ")),
        ])),
        (kind: Group([
            (kind: Property(Artist)),
            (kind: Text(" - ")),
            (kind: Property(Title)),
        ]), default: (kind: Property(Filename)))
    ],
    level_styles: (
        info:  (fg: "#78997A", bg: "#292522"),
        warn:  (fg: "#D47766", bg: "#292522"),
        error: (fg: "#D47766", bg: "#292522"),
        debug: (fg: "#E08A3C", bg: "#292522"),
        trace: (fg: "#B380B0", bg: "#292522"),
    ),
    components: {
        "header": Split(direction: Vertical, panes: [
            (size: "2", borders: "TOP | RIGHT | LEFT", border_symbols: Rounded,
                pane: Split(direction: Horizontal, panes: [
                    (size: "100%", borders: "NONE", pane: Pane(Tabs)),
                ])
            ),
            (size: "4", borders: "ALL", border_symbols: Library("rounded_collapsed_top"),
                border_title: [
                    (kind: Text("╴"), style: (fg: "#E08A3C")),
                    (kind: Property(Song(Bits())), style: (fg: "#867462"), default: (kind: Text("-"), style: (fg: "#867462"))),
                    (kind: Text(" bit · "), style: (fg: "#867462")),
                    (kind: Property(Song(SampleRate())), style: (fg: "#867462"), default: (kind: Text("-"), style: (fg: "#867462"))),
                    (kind: Text(" Hz · "), style: (fg: "#867462")),
                    (kind: Property(Status(Bitrate)), style: (fg: "#867462"), default: (kind: Text("-"), style: (fg: "#867462"))),
                    (kind: Text(" kbps"), style: (fg: "#867462")),
                    (kind: Text("╶"), style: (fg: "#E08A3C")),
                ],
                border_title_position: Bottom,
                border_title_alignment: Right,
                pane: Split(direction: Vertical, panes: [
                    (size: "50%", borders: "NONE", pane: Component("header_line_1")),
                    (size: "50%", borders: "NONE", pane: Component("header_line_2")),
                ])
            ),
        ]),
        "header_line_1": Split(direction: Horizontal, panes: [
            (size: "20%", pane: Pane(Property(content: [
                (kind: Text(" ")),
                (kind: Property(Status(StateV2(playing_label: "󰐊", paused_label: "󰏤", stopped_label: "󰓛"))),
                    style: (fg: "#E08A3C", modifiers: "Bold")),
                (kind: Text("  ")),
                (kind: Property(Status(Elapsed)), style: (fg: "#ECE1D7")),
                (kind: Text(" ∕ "), style: (fg: "#E08A3C")),
                (kind: Property(Status(Duration)), style: (fg: "#867462")),
            ], align: Left))),
            (size: "60%", pane: Pane(Property(content: [
                (kind: Property(Song(Title)), style: (fg: "#E49B5D", modifiers: "Bold"),
                    default: (kind: Property(Song(Filename)), style: (fg: "#E49B5D", modifiers: "Bold"),
                    default: (kind: Text("· · ·"), style: (fg: "#867462")))),
            ], align: Center, scroll_speed: 4))),
            (size: "20%", pane: Pane(Property(content: [
                (kind: Text("󰕾 "), style: (fg: "#E08A3C")),
                (kind: Property(Status(Volume)), style: (fg: "#ECE1D7")),
                (kind: Text("% "), style: (fg: "#867462")),
            ], align: Right))),
        ]),
        "header_line_2": Split(direction: Horizontal, panes: [
            (size: "20%", pane: Pane(Property(content: [
                (kind: Text(" 󰴍 "), style: (fg: "#E08A3C")),
                (kind: Property(Song(Position)), style: (fg: "#ECE1D7"),
                    default: (kind: Text("-"), style: (fg: "#867462"))),
                (kind: Text("/"), style: (fg: "#867462")),
                (kind: Property(Status(QueueLength())), style: (fg: "#ECE1D7")),
                (kind: Text("  󱎫 "), style: (fg: "#E08A3C")),
                (kind: Property(Status(QueueTimeRemaining(separator: " "))), style: (fg: "#867462")),
            ], align: Left))),
            (size: "60%", pane: Pane(Property(content: [
                (kind: Property(Song(Artist)), style: (fg: "#C1A78E"),
                    default: (kind: Text("—"), style: (fg: "#867462"))),
                (kind: Group([
                    (kind: Text("  •  "), style: (fg: "#E08A3C")),
                    (kind: Property(Song(Album)), style: (fg: "#E08A3C")),
                ])),
            ], align: Center, scroll_speed: 4))),
            (size: "20%", pane: Pane(Property(content: [
                (kind: Property(Status(RepeatV2(on_label: " 󰑖 ", off_label: " 󰑖 ",
                    on_style: (fg: "#D47766", modifiers: "Bold"),
                    off_style: (fg: "#867462"))))),
                (kind: Property(Status(RandomV2(on_label: " 󰒝 ", off_label: " 󰒝 ",
                    on_style: (fg: "#D47766", modifiers: "Bold"),
                    off_style: (fg: "#867462"))))),
                (kind: Property(Status(ConsumeV2(on_label: " 󰮯 ", off_label: " 󰮯 ", oneshot_label: " 󰮯¹ ",
                    on_style: (fg: "#D47766", modifiers: "Bold"),
                    off_style: (fg: "#867462"))))),
                (kind: Property(Status(SingleV2(on_label: " 󰎤 ", off_label: " 󰎦 ", oneshot_label: " ¹ ", off_oneshot_label: " ¹ ",
                    on_style: (fg: "#D47766", modifiers: "Bold"),
                    off_style: (fg: "#867462"))))),
                (kind: Text(" ")),
            ], align: Right))),
        ]),
    },
    cava: (
        bar_symbols: ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'],
        bar_width: 2, bar_spacing: 1,
        bg_color: "#292522",
        bar_color: Gradient({
            0:   "#E08A3C",
            33:  "#E08A3C",
            67:  "#E49B5D",
            100: "#C1A78E",
        })
    ),
    lyrics: (
        timestamp: false,
        alignment: Center,
    ),
    border_symbol_sets: {
        "rounded_collapsed_top": (
            parent: Rounded,
            top_left: "├",
            top_right: "┤",
        ),
    },
)
